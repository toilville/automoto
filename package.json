{
  "name": "automoto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=apps/chat",
    "dev:home": "npm run dev --workspace=apps/msr-home",
    "dev:teams": "npm run dev --workspace=apps/teams",
    "dev:agents": "npm run dev --workspace=apps/agents-sdk",
    "dev:m365": "npm run dev --workspace=apps/m365-agents",
    "dev:search-connector": "npm run dev --workspace=apps/copilot-search-connector",
    "dev:knowledge-connector": "npm run dev --workspace=apps/copilot-knowledge-connector",
    "dev:mcp": "npm run dev --workspace=apps/mcp-server",
    "dev:copilot-studio": "npm run dev --workspace=apps/copilot-studio",
    "dev:power-platform": "npm run dev --workspace=apps/power-platform",
    "dev:github-copilot": "npm run dev --workspace=apps/github-copilot-ext",
    "dev:github-cli": "npm run dev --workspace=apps/github-cli-ext",
    "dev:message-ext": "npm run dev --workspace=apps/message-extension",
    "dev:direct-line": "npm run dev --workspace=apps/direct-line",
    "dev:devtools": "npm run dev --workspace=apps/devtools",
    "dev:devtools:mock": "npm run dev:mock --workspace=apps/devtools",
    "dev:gateway": "npm run dev --workspace=apps/gateway",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/ai-projects": "^1.0.0-beta.10",
    "@azure/identity": "^4.13.0",
    "@fluentui/react-components": "^9.72.11",
    "@fluentui/react-icons": "^2.0.315",
    "@griffel/vite-plugin": "^0.1.14",
    "@microsoft/agents-activity": "^1.3.1",
    "@microsoft/agents-hosting": "^1.3.1",
    "@microsoft/agents-hosting-express": "^1.3.1",
    "@microsoft/agents-hosting-extensions-teams": "^1.3.1",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/teams-js": "^2.36.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@automoto/analytics": "*",
    "@automoto/channel-adapter": "*",
    "@automoto/chat-ui": "*",
    "@automoto/data-client": "*",
    "@octokit/webhooks-methods": "^5.0.0",
    "@react-router/dev": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.4",
    "adaptivecards": "^3.0.5",
    "adaptivecards-templating": "^2.3.1",
    "cors": "^2.8.5",
    "eslint": "^8.57.1",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0",
    "isbot": "^5.1.10",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.31.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vite": "^7.2.2",
    "vite-plugin-cjs-interop": "^2.3.0",
    "vitest": "^3.2.4",
    "yaml": "^2.7.0"
  }
}
