{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "22222222-2222-2222-2222-222222222222",
  "packageName": "com.example.microsoftstarter.copilot",
  "developer": {
    "name": "Microsoft Starter Team",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://example.com/privacy",
    "termsOfUseUrl": "https://example.com/terms"
  },
  "name": {
    "short": "MS Starter",
    "full": "Microsoft Starter Copilot Plugin"
  },
  "description": {
    "short": "Generic Copilot plugin starter for recommendation workflows.",
    "full": "A minimal Copilot plugin declaration for invoking recommendation and explanation commands."
  },
  "icons": {
    "outline": "assets/outline-icon-192.png",
    "color": "assets/color-icon-192.png"
  },
  "accentColor": "#004578",
  "composeExtensions": [
    {
      "botId": "22222222-2222-2222-2222-222222222222",
      "canUpdateConfiguration": true,
      "commands": [
        {
          "id": "recommendItems",
          "title": "Recommend Items",
          "description": "Find recommendations based on interests",
          "initialRun": true,
          "context": ["compose", "commandBox"],
          "parameters": [
            {
              "name": "interests",
              "title": "Interests",
              "description": "Comma-separated interests",
              "inputType": "text"
            },
            {
              "name": "maxResults",
              "title": "Max results",
              "description": "Number of suggestions",
              "inputType": "number",
              "value": "5"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["example.com", "tokens.botframework.com"],
  "webApplicationInfo": {
    "id": "22222222-2222-2222-2222-222222222222",
    "resource": "api://example.com/22222222-2222-2222-2222-222222222222"
  }
}
