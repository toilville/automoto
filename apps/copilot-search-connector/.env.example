# Microsoft Graph Connector — App Registration
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# Graph Connector Configuration
CONNECTION_ID=researchContent
CONNECTION_NAME=Research Content
CONNECTION_DESCRIPTION=Research publications, researchers, projects, and news

# Data Source
DATA_API_URL=http://localhost:7071

# Ingestion
INGESTION_BATCH_SIZE=50
INGESTION_RATE_LIMIT_MS=500
