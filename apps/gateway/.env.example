# Gateway server port
PORT=8080

# Upstream service URLs
# Each variable controls where the gateway proxies traffic for that path prefix.

# Web chat app — /chat/*
CHAT_UPSTREAM=http://localhost:5173

# Homepage chat — /home/*
HOME_UPSTREAM=http://localhost:5174

# Teams app — /teams/*
TEAMS_UPSTREAM=http://localhost:5175

# Azure AI Agents SDK app — /agents-sdk/*
AGENTS_SDK_UPSTREAM=http://localhost:5176

# M365 Bot Framework — /m365/*
M365_UPSTREAM=http://localhost:3978

# Teams message extension — /message-ext/*
MESSAGE_EXT_UPSTREAM=http://localhost:7074

# Copilot knowledge connector — /copilot-knowledge/*
COPILOT_KNOWLEDGE_UPSTREAM=http://localhost:8081

# Power Platform connector — /power-platform/*
POWER_PLATFORM_UPSTREAM=http://localhost:7072

# GitHub Copilot extension — /github-copilot/*
GITHUB_COPILOT_UPSTREAM=http://localhost:7073

# Direct Line WebChat widget — /direct-line/*
DIRECT_LINE_UPSTREAM=http://localhost:7075

# MCP SSE server — /mcp/*
MCP_UPSTREAM=http://localhost:3100

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
