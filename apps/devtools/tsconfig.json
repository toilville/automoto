{
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/env.d.ts",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@msr/chat-ui": ["../../packages/chat-ui/src/index.ts"],
      "@msr/data-client": ["../../packages/data-client/src/index.ts"],
      "@msr/analytics": ["../../packages/analytics/src/index.ts"],
      "@msr/analytics/react": ["../../packages/analytics/src/react/index.tsx"],
      "@msr/channel-adapter": ["../../packages/channel-adapter/src/index.ts"]
    }
  }
}
