{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "0.1.0",
  "id": "{{TEAMS_APP_ID}}",
  "developer": {
    "name": "Automoto",
    "websiteUrl": "https://automoto.example.com",
    "privacyUrl": "https://automoto.example.com/privacy",
    "termsOfUseUrl": "https://automoto.example.com/terms"
  },
  "name": {
    "short": "Automoto Assistant",
    "full": "Automoto Assistant"
  },
  "description": {
    "short": "Chat with the Automoto assistant in Microsoft Teams",
    "full": "Discover Automoto content, browse publications, and explore platform updates from within Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "staticTabs": [
    {
      "entityId": "automoto-chat",
      "name": "Automoto Assistant",
      "contentUrl": "https://{{HOSTNAME}}/",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["{{HOSTNAME}}"],
  "defaultInstallScope": "personal",
  "defaultGroupCapability": {}
}
