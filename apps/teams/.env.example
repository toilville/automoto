# Azure AI Foundry Agent (OpenAI Assistants API format)
FOUNDRY_ENDPOINT=https://<your-ai-endpoint>.services.ai.azure.com
FOUNDRY_AGENT_ID=<your-teams-agent-id>
FOUNDRY_API_VERSION=2024-12-01-preview

# Model Inference API (direct model access for lightweight tasks)
MODEL_INFERENCE_ENDPOINT=https://<your-ai-endpoint>.services.ai.azure.com/
MODEL_INFERENCE_MODEL=gpt-4.1

# Authentication (DefaultAzureCredential — managed identity in prod, Azure CLI locally)
# For local dev with managed identity, set:
# AZURE_CLIENT_ID=<your-client-id>

# Data Service API (tool call target for the Foundry agent)
DATA_API_URL=http://localhost:7071

# Microsoft Teams
# Teams app ID (from Teams Developer Portal)
TEAMS_APP_ID=<your-teams-app-id>

# Feature flags
VITE_FEATURE_CHAT_ENABLED=true

# Telemetry / Analytics
VITE_APPINSIGHTS_CONNECTION_STRING=
VITE_APPINSIGHTS_INSTRUMENTATION_KEY=
VITE_ANALYTICS_PROVIDER=1ds
